# ───────────────────────────────────────────────────────────────
#  Zedd Downloader - Konfigurasi Environment (CONTOH)
# ───────────────────────────────────────────────────────────────

# Mode: false = upload ke Google Drive (butuh login)
#       true  = simpan ke folder lokal Desktop/ZEDD_DOWNLOADS (tidak butuh login)
LOCAL_MODE=false

# Dapatkan dari Google Cloud Console (APIs & Services > Credentials)
GOOGLE_CLIENT_ID=GANTI_DENGAN_CLIENT_ID_KAMU.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GANTI_DENGAN_CLIENT_SECRET_KAMU

# Redirect URI yang didaftarkan di Google Dashboard
REDIRECT_URI=http://localhost:8000/auth/callback

# Alamat Frontend kamu (sesuaikan dengan Live Server VSCode)
FRONTEND_URL=http://127.0.0.1:5500/frontend/auth-callback.html
